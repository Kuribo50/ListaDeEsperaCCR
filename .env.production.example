POSTGRES_DB=lista_espera_ccr
POSTGRES_USER=ccr_app
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_DB
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

DJANGO_ENV=production
DJANGO_PRODUCTION=True
DJANGO_SECRET_KEY=CAMBIAR_SECRET_KEY_MUY_LARGA_Y_UNICA
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=ccr.albertoreyes.cl
DJANGO_CSRF_TRUSTED_ORIGINS=https://ccr.albertoreyes.cl
DJANGO_ENABLE_ADMIN=False

DJANGO_DB_ENGINE=postgres
DJANGO_CACHE_BACKEND=redis

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax

JWT_ACCESS_MINUTES=20
JWT_REFRESH_DAYS=7
DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=300/minute
DRF_THROTTLE_AUTH_LOGIN=10/minute
DRF_THROTTLE_AUTH_REFRESH=20/minute

NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_API_PROXY=0
BACKEND_INTERNAL_URL=http://backend:8000
